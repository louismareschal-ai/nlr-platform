# Copy to .env.test and fill in real test credentials
# These are used by the Playwright UI tests (e2e/auth.spec.ts, e2e/super-admin.spec.ts)
# Use dedicated test accounts — not your real super admin password.

E2E_SUPER_ADMIN_EMAIL=
E2E_SUPER_ADMIN_PASSWORD=

# Optional — only needed when squad-admin and player tests are written
E2E_SQUAD_ADMIN_EMAIL=
E2E_SQUAD_ADMIN_PASSWORD=

E2E_PLAYER_EMAIL=
E2E_PLAYER_PASSWORD=
